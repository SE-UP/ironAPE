{
  "constraints": [
    {
      "constraintid": "SLTLx",
      "description": "We have to use 'CreateProject' as the first tool and can not use it subsequently",
      "formula": "Exists (?x) (<'CreateProject'(;?x)> (!F Exists (?y) (<'CreateProject'(;?y)> true)))"
    },
    {
      "constraintid": "depend_m",
      "parameters": [
        { "Tool" : ["CalculateDefectFormationEnergy"]},
