        { "Tool" : ["CreateDefect"]}
      ]
    },
    {
      "constraintid": "depend_m",
      "parameters": [
        { "Tool" : ["CreateVacancyAl"]},
        { "Tool" : ["CalcChemicalPotentialAl"]}
      ]
    },
    {
