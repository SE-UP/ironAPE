    ,{
      "constraintid": "itn_m",
      "parameters": [
        { "Tool" : ["CalcChemicalPotentialAl"]},
        { "Tool" : ["CalcChemicalPotentialAl"]}
      ]
    },
    {
      "constraintid": "itn_m",
      "parameters": [
        { "Tool" : ["CalcChemicalPotentialFe"]},
        { "Tool" : ["CalcChemicalPotentialFe"]}
      ]
    },
    {
      "constraintid": "unique_inputs",
      "parameters": [
        { "Tool" : ["CalculateDefectFormationEnergy"]}
      ]
    },
    {
      "constraintid": "SLTLx",
      "description": "If the tool 'CreateDefect' is used, we eventually have to use 'RelaxStructure' afterwards",
      "formula": "G ((<'CreateDefect'(;)> true) -> (F <'RelaxStructure'(;)> true))"
    },
    {
      "constraintid": "SLTLx",
      "description": "We can not use 'CreateDefect' more than two times",
      "formula": "G ! <'CreateDefect'(;)> F <'CreateDefect'(;)> F <'CreateDefect'(;)> true"
    },
    {
      "constraintid": "SLTLx",
      "description": "We have to use the same DFT method for all energy computations",
      "formula": "(F <'RunVasp'(;)> true) -> !(F <'RunSphinx'(;)> true | F <'RunGpaw'(;)> true)"
    },
    {
      "constraintid": "SLTLx",
      "description": "We have to use the same DFT method for all energy computations",
      "formula": "(F <'RunSphinx'(;)> true) -> !(F <'RunVasp'(;)> true | F <'RunGpaw'(;)> true)"
    },
    {
      "constraintid": "SLTLx",
      "description": "We have to use the same DFT method for all energy computations",
      "formula": "(F <'RunGpaw'(;)> true) -> !(F <'RunSphinx'(;)> true | F <'RunVasp'(;)> true)"
    },
    {
      "constraintid": "SLTLx",
      "description": "We have to use the same DFT method for all relaxations",
      "formula": "(F <'RelaxStructure_VASP'(;)> true) -> !(F <'RelaxStructure_Sphinx'(;)> true | F <'RelaxStructure_GPAW'(;)> true)"
    },
    {
      "constraintid": "SLTLx",
      "description": "We have to use the same DFT method for all relaxations",
      "formula": "(F <'RelaxStructure_Sphinx'(;)> true) -> !(F <'RelaxStructure_VASP'(;)> true | F <'RelaxStructure_GPAW'(;)> true)"
    },
    {
      "constraintid": "SLTLx",
      "description": "We have to use the same DFT method for all relaxations",
      "formula": "(F <'RelaxStructure_GPAW'(;)> true) -> !(F <'RelaxStructure_Sphinx'(;)> true | F <'RelaxStructure_VASP'(;)> true)"
    },
    {
      "constraintid": "SLTLx",
      "description": "We can not use 'RelaxStructure' two times in a row",
      "formula": "G ! (<'RelaxStructure'(;)> <'RelaxStructure'(;)> true)"
    },
    {
      "constraintid": "connected_op",
      "parameters": [
        { "Tool" : ["CreateStructureBulk"]},
        { "Tool" : ["RunDFT"]}
      ]
    }
  ]
