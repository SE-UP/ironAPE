          { "Type": ["Energy"] }
        ],
        "outputs": [
          { "Type": ["DefectFormationEnergy"], "Format": ["Float"] }
        ],
        "implementation": { "code": "# Calculate defect formation energy\ndefectFormationEnergy = energyDefect - energyOriginal + chemPotential\n" }
