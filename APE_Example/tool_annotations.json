          { "Type": ["ChemicalPotential"], "Format": ["Float"] }
        ],
        "outputs": [
          { "Type": ["DefectConcentration"], "Format": ["Float"] }
        ],
        "implementation": { "code": "# Calculate defect concentration\nk_B = 0.0000862\ntemp = 1000\nconcentration_defect = math.exp(-defectFormationEnergy/(k_B * temp))\n" }
