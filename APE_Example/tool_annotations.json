          { "Type": ["DefectConcentration"], "Format": ["Float"] }
        ],
        "outputs": [
          { "Type": ["AlConcentration"], "Format": ["Float"] }
        ],
        "implementation": { "code": "# Calculate Aluminium concentration\nc_Al_AlVac = (1 - c_AlVac)/(2 - c_AlVac)\nc_Al_FeVac = 1/(2 - c_FeVac)\nc_Al = [c_Al_AlVac, c_Al_FeVac]\n" }
      },
